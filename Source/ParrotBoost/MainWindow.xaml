<Window x:Class="ParrotBoost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="ParrotBoost" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        AllowsTransparency="False"
        WindowStyle="None"
        Icon="logo.ico"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        TextOptions.TextHintingMode="Animated"
        RenderOptions.ClearTypeHint="Enabled"
        SnapsToDevicePixels="True"
        RenderOptions.BitmapScalingMode="Fant"
        RenderOptions.EdgeMode="Unspecified">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="45" GlassFrameThickness="0" CornerRadius="20" NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Dynamic Brushes -->
        <SolidColorBrush x:Key="WindowBackground" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#2D3436"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#636E72"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#DFE6E9"/>
        <SolidColorBrush x:Key="HeaderBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ColorPrimaryBrush" Color="#2ECC71"/>
        
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" Direction="270" RenderingBias="Quality" ShadowDepth="1" Opacity="0.08"/>

        <!-- Modern Card Style -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="Fant"/>
        </Style>

        <!-- New Boost Button Style (Round 80px) -->
        <Style x:Key="RoundBoostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ColorPrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle" Fill="{TemplateBinding Background}" StrokeThickness="0">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="12" Color="{Binding Background.Color, RelativeSource={RelativeSource TemplatedParent}}" Opacity="0.3" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="circle" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="35" CenterY="35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ColorPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,10,0">
                            <ContentPresenter x:Name="content" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ColorPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource ColorPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="WindowFrame" Background="{DynamicResource WindowBackground}" CornerRadius="20" SnapsToDevicePixels="True"/>
        <Grid x:Name="RootGrid" Background="{DynamicResource WindowBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Custom Title Bar -->
                <RowDefinition Height="*"/>    <!-- Main Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Panel.ZIndex="10" Height="45" Background="{DynamicResource HeaderBackground}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="20,20,0,0" ClipToBounds="True" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <Image Source="logonbg.png" Width="24" Height="24" RenderOptions.BitmapScalingMode="Fant"/>
                        <TextBlock Text="{DynamicResource MainWindow.Title}" Foreground="{DynamicResource TextPrimary}" Margin="12,0" FontWeight="Bold" VerticalAlignment="Center" FontSize="15"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                            <Button x:Name="ThemeBtn" Style="{StaticResource IconButton}" Click="Theme_Click" Margin="0,0,5,0" ToolTip="Switch Theme" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                            <Button x:Name="SettingsBtn" Style="{StaticResource IconButton}" Click="Settings_Click" Margin="0,0,5,0" ToolTip="Settings" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                            <Button x:Name="MinimizeBtn" Style="{StaticResource IconButton}" Click="Minimize_Click" Margin="0,0,5,0" ToolTip="Minimize" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                            <Button x:Name="CloseButton" Style="{StaticResource IconButton}" Click="Close_Click" ToolTip="Close" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                        </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid x:Name="MainDashboard" Margin="20" Visibility="Visible" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel: Specification (4) and Predicted Boost (3) -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4*"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>

                            <!-- Left Panel - Top: Specs -->
                            <Border Grid.Row="0" Style="{StaticResource ModernCard}" Margin="8" VerticalAlignment="Stretch" Padding="30">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource MainWindow.SystemStatus}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>
                                    <Grid Margin="0,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Fill="{DynamicResource ColorPrimaryBrush}" Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource MainWindow.GpuDrivers}" Foreground="{DynamicResource TextPrimary}" Margin="10,0" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                        <Button x:Name="GpuDriverBtn" Content="{DynamicResource MainWindow.UpToDate}" 
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#2ECC71" FontWeight="SemiBold"
                                                Cursor="Hand" Click="GpuDriverBtn_Click" FontSize="12"/>
                                    </Grid>
                                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,10"/>
                                    <TextBlock Text="{DynamicResource MainWindow.Specs}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="CpuInfo" Text="CPU: Loading..." Foreground="{DynamicResource TextPrimary}" Margin="0,4" TextWrapping="Wrap" FontSize="12"/>
                                    <TextBlock x:Name="GpuInfo" Text="GPU: Loading..." Foreground="{DynamicResource TextPrimary}" Margin="0,4" TextWrapping="Wrap" FontSize="12"/>
                                    <TextBlock x:Name="RamInfo" Text="Memory: Loading..." Foreground="{DynamicResource TextPrimary}" Margin="0,4" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Left Panel - Bottom: Predicted Boost -->
                            <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="8" VerticalAlignment="Stretch">
                                <Grid VerticalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource MainWindow.PredictedBoost}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="BoostPercentage" Text="+5-12%" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource ColorPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource MainWindow.OptimizedPerformance}" Foreground="{DynamicResource TextSecondary}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Right Panel: Logo/Boost (5) and Live Performance (2) -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="5*"/>
                                <RowDefinition Height="2*"/>
                            </Grid.RowDefinitions>

                            <!-- Right Panel - Top: Boost Button & Logo -->
                            <Border Grid.Row="0" Style="{StaticResource ModernCard}" Margin="8" VerticalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Grid x:Name="LogoContainer" Width="130" Height="130" Margin="0,0,0,10">
                                        <Image Source="logonbg.png" Width="100" Height="100" RenderOptions.BitmapScalingMode="Fant">
                                            <Image.Effect>
                                                <DropShadowEffect BlurRadius="24" Color="{Binding Color, Source={StaticResource ColorPrimaryBrush}}" Opacity="0.22" ShadowDepth="0"/>
                                            </Image.Effect>
                                        </Image>
                                        <Grid.RenderTransform>
                                            <TranslateTransform x:Name="LogoFloat" Y="0"/>
                                        </Grid.RenderTransform>
                                    </Grid>
                                    
                                    <Button x:Name="BoostButton" Content="{DynamicResource MainWindow.Boost}" 
                                            Style="{StaticResource RoundBoostButtonStyle}"
                                            Click="BoostButton_Click" Width="70" Height="70" FontSize="15"/>
                                    
                                    <TextBlock x:Name="ProgressStatus" Text="{DynamicResource MainWindow.ReadyToBoost}" 
                                               Margin="0,15,0,0" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="13" FontWeight="Medium"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               MaxWidth="200"/>
                                </StackPanel>
                            </Border>

                            <!-- Right Panel - Bottom: Performance Monitor Bar -->
                            <Border Grid.Row="1" Style="{StaticResource ModernCard}" Margin="8" VerticalAlignment="Stretch" Padding="12,20,12,8">
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="LIVE PERFORMANCE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                    
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- CPU Monitor -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="CPU" Foreground="{DynamicResource TextSecondary}" FontSize="9" FontWeight="Bold" Width="22"/>
                                                <TextBlock x:Name="CpuLoadText" Text="0%" Foreground="{DynamicResource TextPrimary}" FontSize="9" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="CpuTempText" Text="--°C" Foreground="{DynamicResource TextPrimary}" FontSize="9" Margin="6,0"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="CpuLoadBar" Height="5" Minimum="0" Maximum="100" Value="0" Background="{DynamicResource BorderBrush}" BorderThickness="0"/>
                                        </StackPanel>

                                        <!-- GPU Monitor -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="GPU" Foreground="{DynamicResource TextSecondary}" FontSize="9" FontWeight="Bold" Width="22"/>
                                                <TextBlock x:Name="GpuLoadText" Text="0%" Foreground="{DynamicResource TextPrimary}" FontSize="9" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="GpuTempText" Text="--°C" Foreground="{DynamicResource TextPrimary}" FontSize="9" Margin="6,0"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="GpuLoadBar" Height="5" Minimum="0" Maximum="100" Value="0" Background="{DynamicResource BorderBrush}" BorderThickness="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                <!-- Settings Overlay Panel Container -->
                <Grid x:Name="SettingsOverlay" Background="{DynamicResource WindowBackground}" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="5" SnapsToDevicePixels="True">
                    <Grid Margin="25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                                <Button x:Name="BackBtn" Style="{StaticResource IconButton}" Click="Settings_Back_Click" Margin="0,0,15,0" ToolTip="Back">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextPrimary}"/>
                                </Button>
                                <TextBlock Text="{DynamicResource SettingsWindow.Title}" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                                <TabItem Header="{DynamicResource SettingsWindow.General}" Style="{StaticResource TabItemStyle}" Foreground="{DynamicResource TextPrimary}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="10,15">
                                            <TextBlock Text="{DynamicResource SettingsWindow.AppSetting}" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                                            <CheckBox x:Name="LaunchAtStartupCheck" Content="{DynamicResource SettingsWindow.LaunchAtStartup}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="MinimizeToTrayCheck" Content="{DynamicResource SettingsWindow.MinimizeToTray}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            
                                            <TextBlock Text="{DynamicResource SettingsWindow.Language}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" Margin="0,15,0,8" FontSize="14"/>
                                            <ComboBox x:Name="LanguageSelector" Width="200" HorizontalAlignment="Left" SelectionChanged="LanguageSelector_SelectionChanged" Padding="8,5">
                                                <ComboBoxItem Content="English" Tag="en-US"/>
                                                <ComboBoxItem Content="Polski" Tag="pl-PL"/>
                                                <ComboBoxItem Content="Norsk" Tag="nb-NO"/>
                                                <ComboBoxItem Content="Deutsch" Tag="de-DE"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="{DynamicResource SettingsWindow.Performance}" Style="{StaticResource TabItemStyle}" Foreground="{DynamicResource TextPrimary}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="10,15">
                                            <TextBlock Text="{DynamicResource SettingsWindow.OptimizationSteps}" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                                            <CheckBox x:Name="OptServicesCheck" Content="{DynamicResource SettingsWindow.DisableServices}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptMemoryCheck" Content="{DynamicResource SettingsWindow.ClearMemory}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptTasksCheck" Content="Optimize Task Scheduler" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptNtfsCheck" Content="Disable NTFS Last Access" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptPriorityCheck" Content="Optimize Foreground Priority" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptUsbCheck" Content="Disable USB Power Saving" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptDeliveryCheck" Content="Disable Delivery Optimization" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                            <CheckBox x:Name="OptTickCheck" Content="Disable Dynamic Tick" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="{DynamicResource SettingsWindow.Cleanup}" Style="{StaticResource TabItemStyle}" Foreground="{DynamicResource TextPrimary}">
                                    <StackPanel Margin="10,15">
                                        <TextBlock Text="{DynamicResource SettingsWindow.SystemCleanup}" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <CheckBox x:Name="CleanPrefetchCheck" Content="{DynamicResource SettingsWindow.CleanPrefetch}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                        <CheckBox x:Name="CleanTempCheck" Content="{DynamicResource SettingsWindow.CleanTemp}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                        <CheckBox x:Name="CleanWinTempCheck" Content="{DynamicResource SettingsWindow.CleanWinTemp}" Foreground="{DynamicResource TextPrimary}" Margin="0,5" FontSize="13"/>
                                        
                                        <Button Content="{DynamicResource SettingsWindow.Scan}" Margin="0,20,0,8" Click="Scan_Click" Background="{DynamicResource ColorPrimaryBrush}" Foreground="White" Width="150" HorizontalAlignment="Left" Padding="15,8"/>
                                        <TextBlock x:Name="CleanupSizeText" Text="Estimated size: 0 MB" Foreground="{DynamicResource TextSecondary}" FontSize="13"/>
                                        <Button Content="{DynamicResource SettingsWindow.CleanNow}" Margin="0,15" Click="Clean_Click" Background="{DynamicResource ColorPrimaryBrush}" Foreground="White" Width="150" HorizontalAlignment="Left" Padding="15,8"/>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBackground}" Padding="20,12" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="0,0,20,20" ClipToBounds="True">
                <Grid>
                    <TextBlock Text="© 2026 JGS" Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Image Source="logonbg.png" Width="18" Height="18" Opacity="0.6"/>
                        <TextBlock Text="v1.2.6 Stable" Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Splash Screen Overlay -->
            <Grid x:Name="SplashOverlay" Grid.RowSpan="3" Background="{DynamicResource WindowBackground}" Visibility="Visible" IsHitTestVisible="True" Panel.ZIndex="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="SplashLogo" Source="logonbg.png" Width="120" Height="120">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="SplashScale" ScaleX="0.8" ScaleY="0.8" CenterX="60" CenterY="60"/>
                        </Image.RenderTransform>
                    </Image>
                    <TextBlock Text="ParrotBoost" FontSize="26" FontWeight="Bold" Margin="0,25,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                    <ProgressBar IsIndeterminate="True" Width="180" Height="4" Margin="0,35,0,0" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ColorPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
        <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="20" Background="Transparent" IsHitTestVisible="False" Panel.ZIndex="30"/>
    </Grid>
</Window>
